{% extends 'base.html.twig' %}

{% block body %}
	<div class="container-fluid px-2">
		<div class="filter-bar mb-4 p-3 bg-dark text-white rounded shadow-sm">
			<form method="get" action="{{ path('app_home') }}" class="row g-3 align-items-end">
				<div class="col-md-4">
					<label for="genre" class="form-label small fw-bold text-uppercase">Genre</label>
					<select name="genre" id="genre" class="form-select bg-secondary text-white border-0">
						<option value="" class="liste">Tous les genres</option>
						{% for genre in genres %}
							<option class="liste" value="{{ genre.idGenre }}" {{ selectedGenre == genre.idGenre ? 'selected' : '' }}>
								{{ genre.nomGenre }}
							</option>
						{% endfor %}
					</select>
				</div>
				<div class="col-md-4">
					<label for="year" class="form-label small fw-bold text-uppercase">Année</label>
					<select name="year" id="year" class="form-select bg-secondary text-white border-0">
						<option value="" class="liste">Toutes les années</option>
						{% for y in years %}
							<option value="{{ y.annee }}" class="liste" {{ selectedYear == y.annee ? 'selected' : '' }}>
								{{ y.annee }}
							</option>
						{% endfor %}
					</select>
				</div>
				<div class="col-md-4 d-flex gap-2">
					<button type="submit" class="btn btn-primary flex-grow-1 fw-bold">Filtrer</button>
					<a href="{{ path('app_home') }}" class="btn btn-outline-light">Réinitialiser</a>
				</div>
			</form>
		</div>

		<div class="row g-3 justify-content-start films-grid">
			{% for film in films %}
				<div class="col-sm-12 col-md-6 col-lg-3 col-xl-3 d-flex justify-content-center">
					<div class="card film-card text-white position-relative">
						{% if film.affiche %}
							<a href="{{ path('film_show', { id: film.idFilm }) }}">
								<img src="{{ asset(film.affiche) }}" class="card-img-top" alt="{{ film.titre }}">
							</a>
						{% else %}
							<img src="{{ asset('images/default.png') }}" class="card-img-top" alt="Affiche par défaut">
						{% endif %}

						<div class="card-body">
							<h5 class="card-title">
								<a href="{{ path('film_show', { id: film.idFilm }) }}" class="text-decoration-none text-white">
									{{ film.titre }}
								</a>
							</h5>
							<p class="card-text">
								{{ film.annee }}
								{% if film.genres|length > 0 %}
									-
									{{ film.genres|first.getNomGenre() }}
								{% endif %}
							</p>
						</div>
						{% if app.user %}
							<div class="position-absolute top-0 end-0 m-2">
								{% if film in app.user.favoris %}
									<a class="favoris bi bi-heart-fill text-danger fs-3" href="{{ path('favoris_toggle', {id: film.idFilm}) }}" title="Retirer des favoris"></a>
								{% else %}
									<a class="favoris bi bi-heart text-white fs-3" href="{{ path('favoris_toggle', {id: film.idFilm}) }}" title="Ajouter aux favoris"></a>
								{% endif %}
							</div>
						{% endif %}
					</div>

				</div>
			{% endfor %}
		</div>
		<div class="d-flex justify-content-center mt-4">
			{{ knp_pagination_render(films) }}
		</div>
	</div>
{% endblock %}
