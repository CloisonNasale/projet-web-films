{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('build/login.css') }}">
{% endblock %}

{% block body %}
{# Formulaire de connexion pour accéder à son compte #}
<div class="login-container">
    <div class="login-card">
        <form method="post">

            {% if error %}
                <div class="alert alert-error">
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}

            {% if app.user %}
                <div class="already-logged">
                    Vous êtes déjà connecté en tant que {{ app.user.userIdentifier }},
                    <a href="{{ path('app_logout') }}">Déconnexion</a>
                </div>
            {% endif %}

            <h1 class="login-title">Se connecter</h1>

            <div class="form-group">
                <label for="inputMail">Email</label>
                <input
                    type="email"
                    value="{{ last_username }}"
                    name="mail"
                    id="inputMail"
                    autocomplete="email"
                    required
                    autofocus
                >
            </div>

            <div class="form-group">
                <label for="inputPassword">Mot de passe</label>
                <input
                    type="password"
                    name="password"
                    id="inputPassword"
                    autocomplete="current-password"
                    required
                >
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button class="login-button" type="submit">
                Se connecter
            </button>

        </form>
    </div>
</div>
{% endblock %}
