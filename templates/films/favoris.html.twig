{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ encore_entry_link_tags('app') }}
    {% if app.request.attributes.get('_route') in ['profil', 'film_favoris'] %}
        {{ encore_entry_link_tags('profil') }}
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('app') }}
    {% if app.request.attributes.get('_route') in ['profil', 'film_favoris'] %}
        {{ encore_entry_script_tags('profil') }}
    {% endif %}
{% endblock %}

{% block body %}
	{% if app.user %}
		{# Page listant les films favoris de l'utilisateur #}
		<div class="profile-page-container">
			<div class="profile-sidebar">
				<h3 class="mb-4">Profil</h3>
				<a href="{{ path('profil') }}" class="sidebar-link">Profil</a>
				<a href="{{ path('film_favoris') }}" class="sidebar-link active">Mes Favoris</a>
				<a href="#" class="sidebar-link">Mes Commandes</a>
			</div>
			<div class="profile-content">
				<div class="container-fluid px-2">
				<!-- Bouton export CSV -->
				<div class="mb-3">
					<a href="{{ path('favoris_export') }}" class="btn btn-success">
						Exporter mes favoris
					</a>
				</div>
					<div class="row g-3 justify-content-start films-grid">
						{% for film in favoris %}
							<div class="col-sm-12 col-md-6 col-lg-3 col-xl-3 d-flex justify-content-center">
								<div class="card film-card text-white position-relative">
									{% if film.affiche %}
										<a href="{{ path('film_show', { id: film.idFilm }) }}">
											<img src="{{ asset(film.affiche) }}" class="card-img-top" alt="{{ film.titre }}">
										</a>
									{% else %}
										<img src="{{ asset('images/default.png') }}" class="card-img-top" alt="Affiche par défaut">
									{% endif %}

									<div class="card-body">
										<h5 class="card-title">
											<a href="{{ path('film_show', { id: film.idFilm }) }}" class="text-decoration-none text-white">
												{{ film.titre }}
											</a>
										</h5>
										<p class="card-text">
											{{ film.annee }}
											{% if film.genres|length > 0 %}
												-
												{{ film.genres|first.getNomGenre() }}
											{% endif %}
										</p>
									</div>

									<div class="position-absolute top-0 end-0 m-2">
										{% if film in app.user.favoris %}
											<a class="favoris favoris-toggle bi bi-heart-fill text-danger fs-3" 
											   href="{{ path('favoris_toggle', {id: film.idFilm}) }}" 
											   data-film-id="{{ film.idFilm }}"
											   title="Retirer des favoris"></a>
										{% else %}
											<a class="favoris favoris-toggle bi bi-heart text-white fs-3" 
											   href="{{ path('favoris_toggle', {id: film.idFilm}) }}" 
											   data-film-id="{{ film.idFilm }}"
											   title="Ajouter aux favoris"></a>
										{% endif %}
									</div>
								</div>
							</div>
						{% endfor %}
					</div>
				</div>
			</div>
		</div>
	{% endif %}

	<script>
		// Gère le toggle des favoris via AJAX sur la page favoris
		document.querySelectorAll('.favoris-toggle').forEach(link => {
			link.addEventListener('click', function(e) {
				e.preventDefault();
				
				const url = this.href;
				const filmId = this.dataset.filmId;
				const filmCard = this.closest('.col-sm-12');
				
				fetch(url, {
					headers: {
						'X-Requested-With': 'XMLHttpRequest'
					}
				})
				.then(response => response.json())
				.then(data => {
					if (data.success) {
						// Si on retire des favoris, on masque la carte avec une animation
						if (!data.isFavorite) {
							filmCard.style.transition = 'opacity 0.3s ease';
							filmCard.style.opacity = '0';
							setTimeout(() => {
								filmCard.remove();
								// Si plus de favoris, afficher un message
								const filmsGrid = document.querySelector('.films-grid');
								if (filmsGrid.children.length === 0) {
									filmsGrid.innerHTML = '<div class="col-12 text-center text-white"><p>Vous n\'avez pas encore de favoris.</p></div>';
								}
							}, 300);
						} else {
							// Si on ajoute aux favoris (ne devrait pas arriver sur cette page)
							this.classList.remove('bi-heart', 'text-white');
							this.classList.add('bi-heart-fill', 'text-danger');
							this.title = 'Retirer des favoris';
						}
					}
				})
				.catch(error => console.error('Error:', error));
			});
		});
	</script>
{% endblock %}
