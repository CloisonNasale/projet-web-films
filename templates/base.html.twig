<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<title>
			{% block title %}Symfony
			{% endblock %}
		</title>

		<!-- BOOTSTRAP CSS -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
		<link
		rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

		<!-- CSS compilé par Webpack Encore -->
		{% block stylesheets %}
			<link rel="stylesheet" href="{{ asset('build/app.css') }}">
		{% endblock %}
	</head>

	<body
		class="text-white">

		<!-- NAVBAR BOOTSTRAP -->
		<nav class="navbar navbar-expand-lg navbar-dark border-bottom border-secondary fixed-top">
			<div class="container">
				<a class="navbar-brand fw-bold" href="{{ path('app_home') }}">🎬 Films</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
					<span class="navbar-toggler-icon"></span>
				</button>

				<div class="collapse navbar-collapse justify-content-end" id="navbarNav">
					<ul class="navbar-nav">
						<li class="nav-item">
							<a class="nav-link {% if app.request.attributes.get('_route') == 'app_home' %}active{% endif %}" href="{{ path('app_home') }}">
								Films
							</a>
						</li>
						{% if app.user %}
							<li class="nav-item dropdown">
								<a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
									<i class="bi bi-person-circle"></i>
									{{ app.user.prenom }}
									{{ app.user.nom }}
								</a>
								<ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
									<li>
										<a class="dropdown-item" href="{{ path('profil') }}">Mon Profil</a>
									</li>
									<li>
										<a class="dropdown-item" href="{{ path('app_logout') }}">Déconnexion</a>
									</li>

								</ul>
							</li>
						{% else %}
							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_login') }}">Se connecter</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_register') }}">S'inscrire</a>
							</li>
						{% endif %}
					</ul>
				</div>
			</div>
		</nav>

		<!-- ESPACE POUR ÉVITER QUE LE HEADER FIXE CACHE LE CONTENU -->
		<div style="height:50px;"></div>

		<main class="container mt-4"> {% block body %}{% endblock %}
			</main>

			<!-- JS compilé par Webpack Encore -->
			<script src="{{ asset('build/app.js') }}"></script>

			<!-- BOOTSTRAP JS -->
			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

		</body>
	</html>
