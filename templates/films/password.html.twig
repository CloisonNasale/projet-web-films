{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ encore_entry_link_tags('app') }}
    {# Always link profil.css as requested #}
    {{ encore_entry_link_tags('profil') }}
    {# Link the new password.css #}
    {{ encore_entry_link_tags('password') }}

{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('app') }}
    {{ encore_entry_script_tags('profil') }}
{% endblock %}

{% block body %}
    {% if app.user %}
        {# Page de profil utilisateur (informations personnelles et actions) #}
        <div class="profile-page-container">
            <div class="profile-sidebar">
                <h3 class="mb-4">Profil</h3>
                <a href="{{ path('profil') }}" class="sidebar-link">Profil</a>
                <a href="{{ path('film_favoris') }}" class="sidebar-link">Mes Favoris</a>
                <a href="{{ path('film_commande') }}" class="sidebar-link">Mes Commandes</a>
                {# Assuming there might be a link for 'Security' or similar, but for now just keeping existing sidebar #}
            </div>

            <div class="profile-content">
                <div class="password-card">
                    <h2>Changer mon mot de passe</h2>

                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger">{{ message }}</div>
                    {% endfor %}

                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success">{{ message }}</div>
                    {% endfor %}

                    <form method="POST">
                        <input type="hidden" name="_token" value="{{ csrf_token('change_password') }}">

                        <div class="form-group">
                            <label for="current_password">Mot de passe actuel</label>
                            <input type="password" id="current_password" name="current_password" required>
                        </div>

                        <div class="form-group">
                            <label for="new_password">Nouveau mot de passe</label>
                            <input type="password" id="new_password" name="new_password" required>
                        </div>

                        <div class="form-group">
                            <label for="confirm_password">Confirmer le mot de passe</label>
                            <input type="password" id="confirm_password" name="confirm_password" required>
                        </div>

                        <button type="submit" class="btn-password-submit">
                            Mettre à jour
                        </button>
                    </form>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
