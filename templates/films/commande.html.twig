{% extends 'base.html.twig' %}
{% block stylesheets %}
	{{ encore_entry_link_tags('app') }}
	{% if app.request.attributes.get('_route') in ['profil', 'film_commande'] %}
		{{ encore_entry_link_tags('profil') }}
        <link rel="stylesheet" href="{{ 'assets/css/commande.css' }}">
	{% endif %}
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('app') }}
    {% if app.request.attributes.get('_route') in ['profil', 'film_commande'] %}
        {{ encore_entry_script_tags('profil') }}
    {% endif %}
{% endblock %}

{% block body %}
	{% if app.user %}
		<div class="profile-page-container">
			<div class="profile-sidebar">
				<h3 class="mb-4">Profil</h3>
				<a href="{{ path('profil') }}" class="sidebar-link">Profil</a>
				<a href="{{ path('film_favoris') }}" class="sidebar-link">Mes Favoris</a>
				<a href="{{ path('film_commande') }}" class="sidebar-link active">Mes Commandes</a>
			</div>
			<div class="profile-content">
				<div class="container-fluid px-2">
					<div class="row g-3 justify-content-start films-grid">
						{% for commande in commandes %}
							{% set total = 0 %}
							{% for film in commande.films %}
								{% if film.prix %}
									{% set total = total + film.prix.prix %}
								{% endif %}
							{% endfor %}
							
							<div class="commande-card mb-4">
								<div class="commande-header">
									<h5 class="mb-0">
										Commande du {{ commande.dateCommande|date('d/m/Y') }}
									</h5>
									<span class="commande-total">Total: {{ total }} €</span>
								</div>
								
								<div class="commande-items mt-3">
									{% for film in commande.films %}
										<div class="commande-item">
											<span class="film-title">{{ film.titre }}</span>
											<span class="film-price">
												{% if film.prix %}
													{{ film.prix.prix }} €
												{% else %}
													N/A
												{% endif %}
											</span>
										</div>
									{% endfor %}
								</div>
							</div>
						{% else %}
							<p>Aucune commande.</p>
						{% endfor %}

					</div>
				</div>
			</div>
		</div>
	{% endif %}
{% endblock %}
