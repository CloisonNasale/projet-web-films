<form method="post" action="{{ path('app_films_admin_delete', {'id': film.idFilm}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ film.idFilm) }}">
    <button class="btn btn-danger btn-sm">Supprimer</button>
</form>
