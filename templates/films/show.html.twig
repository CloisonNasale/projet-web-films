{% extends 'base.html.twig' %}

{% block body %}
<div class="container mt-5">

    <div class="row">
        <!-- Colonne gauche : affiche + prix -->
        <div class="col-lg-5 col-md-5 d-flex flex-column align-items-center mb-4">
            <div class="position-relative">
                {% if film.affiche %}
                    <img src="{{ asset(film.affiche) }}" class="img-fluid rounded" alt="{{ film.titre }}" style="max-height: 700px; width: auto;">
                {% else %}
                    <img src="{{ asset('images/default.png') }}" class="img-fluid rounded" alt="Affiche par défaut" style="max-height: 700px; width: auto;">
                {% endif %}

                <!-- Étoile avec la note en haut à gauche -->
                <div class="position-absolute top-0 start-0 m-2 p-1 bg-warning text-dark rounded">
                    <i class="bi bi-star-fill"></i> {{ film.classementIMDB }}
                </div>

                <!-- Bouton favoris en bas à droite -->
                <button class="position-absolute bottom-0 end-0 m-2 p-2 favorite-btn not-favorited" title="Ajouter aux favoris">
                    <i class="bi bi-heart fs-4"></i>
                </button>
            </div>

            <!-- Prix sous l'affiche -->
            <div class="mt-3 p-1 bg-light text-dark rounded text-center w-25">
                <strong>Prix :</strong> {{ film.prix.prix }} €
            </div>

            <!-- Ajouter au panier -->
            <a href="#" class="btn btn-danger mt-2 d-flex justify-content-center align-items-center" 
            style="width: 50px; height: 35px; padding: 0;" title="Ajouter au panier">
                <i class="bi bi-cart-plus fs-5"></i>
            </a>
        </div>

        <!-- Colonne droite : informations film -->
        <div class="col-lg-7 col-md-7">
            <!-- Titre -->
            <h1 class="d-flex justify-content-between align-items-center mb-3">
                {{ film.titre }}
                <a href="{{ path('app_home') }}" class="text-light fs-3 text-decoration-none">
                    <i class="bi bi-arrow-left-circle-fill"></i>
                </a>
            </h1>

            <!-- Année et genres -->
            <p class="text-secondary mb-2">
                <strong>Année :</strong> {{ film.annee }}
            </p>
            <p class="text-secondary mb-4">
                <strong>Genres :</strong>
                {% for genre in film.genres %}
                    <span class="badge bg-secondary me-1 mb-1">{{ genre.nomGenre }}</span>
                {% else %}
                    <span>Aucun genre</span>
                {% endfor %}
            </p>

            <!-- Synopsis -->
            <h4>Description :</h4>
            <p class="mb-4">{{ film.synopsis }}</p>

            <!-- Acteurs -->
            <h4>Acteurs :</h4>
            {% if acteurs|length > 0 %}
                <div class="d-flex flex-wrap mb-4">
                    {% for acteur in acteurs %}
                        <span class="badge bg-light text-dark me-2 mb-2 p-2 fs-6">{{ acteur.nomActeur }}</span>
                    {% endfor %}
                </div>
            {% else %}
                <p>Aucun acteur pour ce film.</p>
            {% endif %}

            <!-- Bande annonce -->
            {% if film.bandeAnnonce %}
                <h4>Bande Annonce :</h4>
                <div class="ratio ratio-16x9 mb-4">
                    <iframe 
                        src="https://www.youtube.com/embed/{{ film.bandeAnnonce | replace({'https://www.youtube.com/watch?v=':''}) }}" 
                        title="Bande annonce {{ film.titre }}" 
                        allowfullscreen>
                    </iframe>
                </div>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}
