{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ encore_entry_link_tags('app') }}
    {% if app.request.attributes.get('_route') == 'film_show' %}
        {{ encore_entry_link_tags('show') }}
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ encore_entry_script_tags('app') }}
    {% if app.request.attributes.get('_route') == 'film_show' %}
        {{ encore_entry_script_tags('show') }}
    {% endif %}
{% endblock %}


{% block body %}
{# Page de détails d'un film (affiche, synopsis, acteurs, etc.) #}
<div class="film-container">

    <div class="film-layout">

        <!-- Colonne gauche -->
        <div class="film-left">
            <div class="poster-wrapper">

                {% if film.affiche %}
                    <img src="{{ asset(film.affiche) }}" alt="{{ film.titre }}" class="film-poster">
                {% else %}
                    <img src="{{ asset('images/default.png') }}" alt="Affiche par défaut" class="film-poster">
                {% endif %}

                <!-- Note -->
                <div class="film-rating">
                    ★ {{ film.classementIMDB }}
                </div>

                <!-- Favoris -->
                <button class="favorite-btn" title="Ajouter aux favoris">
                    ♥
                </button>
            </div>

            <!-- Prix -->
            <div class="film-price">
                <strong>Prix :</strong> {{ film.prix.prix }} €
            </div>

            <!-- Panier -->
            {% if app.user %}
                {% if film in app.user.panier %}
                    <button class="add-cart-btn" style="background-color: #198754; cursor: default;" disabled title="Déjà au panier">
                        ✔
                    </button>
                {% else %}
                    <button class="add-cart-btn btn-add-panier" data-movie-id="{{ film.idFilm }}" title="Ajouter au panier" style="border: none; cursor: pointer;">
                        🛒
                    </button>
                {% endif %}
            {% else %}
                <a href="{{ path('app_login') }}" class="add-cart-btn" title="Connectez-ou pour ajouter au panier">
                    🛒
                </a>
            {% endif %}
        </div>

        <!-- Colonne droite -->
        <div class="film-right">

            <h1 class="film-title">
                {{ film.titre }}
                <a href="{{ path('app_home') }}" class="back-btn">←</a>
            </h1>

            <p class="film-meta">
                <strong>Année :</strong> {{ film.annee }}
            </p>

            <div class="film-genres">
                <strong>Genres :</strong>
                {% for genre in film.genres %}
                    <span class="genre-badge">{{ genre.nomGenre }}</span>
                {% else %}
                    <span>Aucun genre</span>
                {% endfor %}
            </div>

            <h4>Description :</h4>
            <p class="film-description">{{ film.synopsis }}</p>

            <h4>Acteurs :</h4>
            {% if acteurs|length > 0 %}
                <div class="actors-list">
                    {% for acteur in acteurs %}
                        <span class="actor-badge">{{ acteur.nomActeur }}</span>
                    {% endfor %}
                </div>
            {% else %}
                <p>Aucun acteur pour ce film.</p>
            {% endif %}

            {% if film.bandeAnnonce %}
                <h4>Bande annonce :</h4>
                <div class="video-wrapper">
                    <iframe
                        src="https://www.youtube.com/embed/{{ film.bandeAnnonce|replace({'https://www.youtube.com/watch?v=':''}) }}"
                        title="Bande annonce {{ film.titre }}"
                        allowfullscreen>
                    </iframe>
                </div>
            {% endif %}

        </div>
    </div>

</div>
{% endblock %}
